{
  "name": "palarealestate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "PRISMA_CLIENT_ENGINE_TYPE=binary next build",
    "start": "PRISMA_CLIENT_ENGINE_TYPE=binary next start",
